{
    "name": "@kartoffelgames/environment-bundle",
    "version": "5.0.0",
    "license": "LGPL-3.0-only",
    "tasks": {},
    "imports": {},
    "exports": "./source/index.ts",
    "publish": {
        "include": [
            "source/",
            "deno.json",
            "LICENSE"
        ]
    },
    "kg": {
        "name": "Kartoffelgames.Environment.Bundle",
